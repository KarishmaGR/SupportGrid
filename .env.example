# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database (Railway provides this automatically) ────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-char-minimum-secret-here
# Set to your Railway public URL, e.g. https://supportgrid.up.railway.app
BETTER_AUTH_URL=https://your-app.up.railway.app

# ── CORS ─────────────────────────────────────────────────────
# Same value as BETTER_AUTH_URL (frontend is served from the same origin)
ALLOWED_ORIGINS=https://your-app.up.railway.app

# ── Webhooks ──────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret

# ── AI (OpenRouter) ───────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=SupportGrid

# ── Optional: Seed (run manually after first deploy) ─────────
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=SecurePassword@123
